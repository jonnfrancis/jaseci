# Required for the scaled production database. Local single-process development
# may omit this to use Jac's SQLite graph store.
MONGODB_URI=mongodb://username:password@host:27017/graphlearn

# Required outside local testing. Generate a long random value.
JWT_SECRET=replace-with-a-long-random-secret

# Required for live AI generation; deterministic tests do not need it.
VITE_GEMINI_API_KEY=replace-with-provider-key

# Structured backend observability. Payload/code logging stays disabled by default.
OBSERVABILITY_ENABLED=true
TRACE_ENABLED=true
METRICS_ENABLED=true
LOG_LEVEL=info
LOG_AI_PAYLOADS=false
LOG_SUBMISSION_CODE=false
OBSERVABILITY_WALKER_SLOW_MS=1000
OBSERVABILITY_AI_SLOW_MS=10000
OBSERVABILITY_DASHBOARD_SLOW_MS=2000

# Lecturer authorization defaults. Production should retain strict values.
ALLOW_LECTURER_SELF_APPROVAL=false
ALLOW_LECTURER_SELF_PUBLISH=true
ALLOW_OWNER_SCALAR_FALLBACK=false
ALLOW_OWNER_RESTORE=false
AUTHORIZATION_AUDIT_DENIES=true
PRIVATE_RESOURCE_HIDE_EXISTENCE=true

# Course-document storage. Local development uses this private directory.
# Production must mount it on durable shared storage or replace the adapter.
COURSE_DOCUMENT_STORAGE_BASE=./storage/course-documents
COURSE_DOCUMENT_MAX_BYTES=52428800
COURSE_DOCUMENT_MIN_BYTES=1
COURSE_DOCUMENT_RETENTION_DAYS=30
COURSE_DOCUMENT_ORPHAN_GRACE_MINUTES=60
COURSE_DOCUMENT_TMP_PREFIX=_tmp
COURSE_DOCUMENT_TRASH_PREFIX=_trash
# Set to scaled/multi-pod/multi-instance in replicated deployments. Local
# storage then fails readiness instead of pretending to be shared durable data.
COURSE_DOCUMENT_DEPLOYMENT_MODE=development
