"""Low-cardinality metrics for blueprint AI contract execution."""
glob BLUEPRINT_LLM_METRICS: dict[str, int] = {};
def record_blueprint_llm(operation: str, result: str, duration_ms: int = 0, input_tokens: int = 0, output_tokens: int = 0, count: int = 0) { for key in ["blueprint_llm_calls_total", "blueprint_llm_" + result.lower() + "_total", "blueprint_llm_operation_" + operation.lower() + "_total"] { BLUEPRINT_LLM_METRICS[key] = BLUEPRINT_LLM_METRICS.get(key, 0) + 1; } BLUEPRINT_LLM_METRICS["blueprint_llm_duration_ms"] = BLUEPRINT_LLM_METRICS.get("blueprint_llm_duration_ms", 0) + duration_ms; BLUEPRINT_LLM_METRICS["blueprint_llm_input_tokens_total"] = BLUEPRINT_LLM_METRICS.get("blueprint_llm_input_tokens_total", 0) + input_tokens; BLUEPRINT_LLM_METRICS["blueprint_llm_output_tokens_total"] = BLUEPRINT_LLM_METRICS.get("blueprint_llm_output_tokens_total", 0) + output_tokens; BLUEPRINT_LLM_METRICS["blueprint_" + operation.lower() + "_total"] = BLUEPRINT_LLM_METRICS.get("blueprint_" + operation.lower() + "_total", 0) + count; }
def blueprint_llm_metric(name: str) -> int { return BLUEPRINT_LLM_METRICS.get(name, 0); }
