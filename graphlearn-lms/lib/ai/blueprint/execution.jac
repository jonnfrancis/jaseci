"""Safe execution provenance, cache identity, and observability helpers for Feature 46 orchestration."""
import hashlib;
import from lib.ai.blueprint.contracts { ByLLMExecutionMetadata }
import from lib.ai.blueprint.metrics { record_blueprint_llm }
import from lib.ai.blueprint.prompts { BLUEPRINT_CONTRACT_SCHEMA_VERSION }
import from lib.learning_track.application_services { service_now }
import from lib.observability.events { ObservabilityEvent }
import from lib.observability.logger { emit_event }

def chunk_analysis_cache_key(chunk_id: str, content_hash: str, prompt_version: int, schema_version: int = BLUEPRINT_CONTRACT_SCHEMA_VERSION) -> str { raw = "chunk-analysis:" + chunk_id + ":" + content_hash + ":" + str(prompt_version) + ":" + str(schema_version); return hashlib.sha256(raw.encode("utf-8")).hexdigest(); }

def start_blueprint_execution(execution_id: str, operation: str, prompt_version: int, provider: str | None = None, model: str | None = None) -> ByLLMExecutionMetadata { metadata = ByLLMExecutionMetadata(execution_id=execution_id, operation=operation, provider=provider, model=model, prompt_version=prompt_version, schema_version=BLUEPRINT_CONTRACT_SCHEMA_VERSION, started_at=service_now(), attempt_count=1, success=False); emit_event(ObservabilityEvent(timestamp=metadata.started_at, level="info", event="blueprint_llm." + operation + "_started", status="started", message="Blueprint AI operation started.", request_id=execution_id, correlation_id=execution_id, attributes={"operation": operation, "prompt_version": prompt_version, "schema_version": BLUEPRINT_CONTRACT_SCHEMA_VERSION, "provider": provider or "", "model": model or "", "attempt": 1})); return metadata; }

def finish_blueprint_execution(metadata: ByLLMExecutionMetadata, success: bool, duration_ms: int, error_code: str | None = None, input_tokens: int | None = None, output_tokens: int | None = None) -> ByLLMExecutionMetadata { metadata.completed_at = service_now(); metadata.success = success; metadata.error_code = error_code; metadata.input_token_count = input_tokens; metadata.output_token_count = output_tokens; record_blueprint_llm(metadata.operation, "completed" if success else "failures", duration_ms, input_tokens or 0, output_tokens or 0); emit_event(ObservabilityEvent(timestamp=metadata.completed_at as str, level="info" if success else "error", event="blueprint_llm." + metadata.operation + ("_completed" if success else "_failed"), status="completed" if success else "failed", message="Blueprint AI operation completed." if success else "Blueprint AI operation failed.", request_id=metadata.execution_id, correlation_id=metadata.execution_id, duration_ms=duration_ms, error_code=error_code or "", attributes={"operation": metadata.operation, "prompt_version": metadata.prompt_version, "schema_version": metadata.schema_version, "provider": metadata.provider or "", "model": metadata.model or "", "attempt": metadata.attempt_count, "input_token_count": input_tokens or 0, "output_token_count": output_tokens or 0})); return metadata; }
