"""Safe low-cardinality telemetry for blueprint generation orchestration."""
import from lib.learning_track.application_services { service_now }
import from lib.observability.events { ObservabilityEvent }
import from lib.observability.logger { emit_event }

glob BLUEPRINT_GENERATION_METRICS: dict[str, int] = {};
def record_blueprint_generation(result: str, duration_ms: int = 0, concepts: int = 0, modules: int = 0, outcomes: int = 0, prerequisites: int = 0, cache_hits: int = 0) { for key in ["blueprint_generation_total", "blueprint_generation_" + result.lower() + "_total"] { BLUEPRINT_GENERATION_METRICS[key] = BLUEPRINT_GENERATION_METRICS.get(key, 0) + 1; } BLUEPRINT_GENERATION_METRICS["blueprint_generation_duration_ms"] = BLUEPRINT_GENERATION_METRICS.get("blueprint_generation_duration_ms", 0) + duration_ms; BLUEPRINT_GENERATION_METRICS["blueprint_concepts_generated"] = BLUEPRINT_GENERATION_METRICS.get("blueprint_concepts_generated", 0) + concepts; BLUEPRINT_GENERATION_METRICS["blueprint_modules_generated"] = BLUEPRINT_GENERATION_METRICS.get("blueprint_modules_generated", 0) + modules; BLUEPRINT_GENERATION_METRICS["blueprint_outcomes_generated"] = BLUEPRINT_GENERATION_METRICS.get("blueprint_outcomes_generated", 0) + outcomes; BLUEPRINT_GENERATION_METRICS["blueprint_prerequisites_generated"] = BLUEPRINT_GENERATION_METRICS.get("blueprint_prerequisites_generated", 0) + prerequisites; BLUEPRINT_GENERATION_METRICS["blueprint_chunk_analysis_cache_hit_total"] = BLUEPRINT_GENERATION_METRICS.get("blueprint_chunk_analysis_cache_hit_total", 0) + cache_hits; }
def blueprint_generation_event(name: str, track_id: str, track_version_id: str, document_id: str, chunk_set_id: str, run_id: str, step: str, status: str = "completed", error_code: str = "") { emit_event(ObservabilityEvent(timestamp=service_now(), level="error" if status == "failed" else "info", event="blueprint_generation." + name, status=status, message="Blueprint generation stage changed.", request_id=run_id, correlation_id=run_id, error_code=error_code, entity_ids={"generation_run_id": run_id, "track_id": track_id, "track_version_id": track_version_id, "document_id": document_id, "chunk_set_id": chunk_set_id}, attributes={"step": step, "schema_version": 1})); }
