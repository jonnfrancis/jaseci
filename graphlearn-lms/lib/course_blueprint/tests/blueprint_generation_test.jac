"""Offline Feature 46 orchestration, persistence, idempotency, and safety tests."""
import from uuid { uuid4 }
import from edges.domain_edges { HAS_CHUNK_SET, HAS_CONTENT_CHUNK, HAS_EXTRACTION, HAS_SOURCE_DOCUMENT }
import from lib.ai.blueprint.contracts { BlueprintConfidence, BlueprintCritique, BlueprintCritiqueInput, BlueprintEvidenceRef, BlueprintLearningOutcome, BlueprintPrerequisiteCandidate, BlueprintSynthesisInput, ConceptMergeInput, CourseBlueprintDraft, CourseChunkAnalysis, CourseChunkAnalysisInput, CourseConceptCandidate, CourseConceptType, CourseModuleDraft, EvidenceStrength, LearningObjectiveLevel, MergedCourseConcept, ModuleImportance, PrerequisiteInferenceInput }
import from lib.course_blueprint.ai_adapter { BlueprintGenerationAI }
import from lib.course_blueprint.generation_service { CourseBlueprintGenerationService }
import from lib.course_blueprint.planner { default_blueprint_generation_config, plan_analysis_units }
import from lib.course_blueprint.repositories { BlueprintGenerationArtifactRepository, CourseBlueprintRepository }
import from lib.course_document.processing_job_repository { DocumentProcessingJobRepository }
import from lib.course_document.processing_service { DocumentProcessingOrchestrator }
import from lib.learning_track.application_services { service_now }
import from lib.learning_track.course_management { create_course_service }
import from lib.learning_track.repositories { repository_find_track, repository_versions }
import from lib.learning_track.repository_types { ActorContext }
import from nodes.curriculum { BlueprintGenerationContext, BlueprintGenerationStatus, CourseContentChunk, CourseDocument, CourseDocumentProcessingStatus, CourseDocumentUploadStatus, DocumentChunkSet, DocumentChunkingStatus, DocumentExtraction, DocumentExtractionStatus, DocumentProcessingStage, DocumentValidationStatus, ProcessingJobStatus }
import from nodes.learning_track { CreateCourseTrackInput, LearningTrack, LecturerCourseDetail }

obj MockGenerationAI(BlueprintGenerationAI) {
    has analysis_output: CourseChunkAnalysis;
    has merge_output: list[MergedCourseConcept];
    has synthesis_output: CourseBlueprintDraft;
    has prerequisite_output: list[BlueprintPrerequisiteCandidate];
    has critique_output: BlueprintCritique;
    has analyze_calls: int = 0, merge_calls: int = 0, synthesis_calls: int = 0;
    def analyze(input: CourseChunkAnalysisInput) -> CourseChunkAnalysis { _ = input; self.analyze_calls += 1; return self.analysis_output; }
    def merge(input: ConceptMergeInput) -> list[MergedCourseConcept] { _ = input; self.merge_calls += 1; return self.merge_output; }
    def synthesize(input: BlueprintSynthesisInput) -> CourseBlueprintDraft { _ = input; self.synthesis_calls += 1; return self.synthesis_output; }
    def infer(input: PrerequisiteInferenceInput) -> list[BlueprintPrerequisiteCandidate] { _ = input; return self.prerequisite_output; }
    def critique(input: BlueprintCritiqueInput) -> BlueprintCritique { _ = input; return self.critique_output; }
}

def _fixture(suffix: str) -> tuple[LearningTrack, CourseDocument, DocumentChunkSet, CourseContentChunk] {
    actor = ActorContext(user_id="user_" + suffix, lecturer_id="lecturer_" + suffix, request_id="request_" + suffix, roles=["LECTURER"]); created = create_course_service(actor, CreateCourseTrackInput(title="Database Systems " + suffix[:5], client_request_id="course_" + suffix)); detail = created.value as LecturerCourseDetail; track = repository_find_track(detail.track.track_id) as LearningTrack; version = repository_versions(track)[0]; now = service_now();
    document = CourseDocument(document_id="doc_" + suffix, track_id=track.track_id, track_version_id=version.track_version_id, original_filename="notes.pdf", normalized_filename="notes.pdf", mime_type="application/pdf", file_extension="pdf", file_size_bytes=2000, storage_provider="test", storage_key="test/notes.pdf", checksum_algorithm="sha256", checksum="checksum_" + suffix, upload_status=CourseDocumentUploadStatus.STORED, processing_status=CourseDocumentProcessingStatus.ANALYZING, uploaded_by=actor.user_id, uploaded_at=now, updated_at=now, idempotency_scope="scope_" + suffix, validation_status=DocumentValidationStatus.VALIDATED, extraction_status=DocumentExtractionStatus.EXTRACTED, chunking_status=DocumentChunkingStatus.CHUNKED); version +>:HAS_SOURCE_DOCUMENT(attached_at=now, attached_by=actor.user_id):+> document;
    extraction = DocumentExtraction(extraction_id="ext_" + suffix, document_id=document.document_id, track_id=track.track_id, track_version_id=version.track_version_id, status=DocumentExtractionStatus.EXTRACTED, extractor_name="test", extractor_version="1", source_checksum_sha256=document.checksum, completed_at=now); document +>:HAS_EXTRACTION(created_at=now):+> extraction;
    chunk_set = DocumentChunkSet(chunk_set_id="chs_" + suffix, document_id=document.document_id, extraction_id=extraction.extraction_id, track_id=track.track_id, track_version_id=version.track_version_id, source_checksum_sha256=document.checksum, schema_version=1, strategy_name="structural-v1", config_hash="cfg", status=DocumentChunkingStatus.CHUNKED, created_at=now, chunk_count=1, source_coverage_ratio=1.0, is_active=True, completed_at=now); extraction +>:HAS_CHUNK_SET(created_at=now):+> chunk_set;
    chunk = CourseContentChunk(chunk_id="chk_" + suffix, document_id=document.document_id, extraction_id=extraction.extraction_id, track_id=track.track_id, track_version_id=version.track_version_id, chunking_strategy="structural-v1", order_index=0, content="Database normalization reduces update anomalies.", character_count=48, word_count=6, estimated_token_count=10, source_block_ids_json="[]", content_hash="hash_" + suffix, created_at=now, page_start=1, page_end=1); chunk_set +>:HAS_CONTENT_CHUNK(order_index=0):+> chunk; return (track, document, chunk_set, chunk);
}

def _mock(chunk_id: str) -> MockGenerationAI {
    ref = BlueprintEvidenceRef(chunk_id=chunk_id, quote_hint="normalization", page_start=1, page_end=1, strength=EvidenceStrength.DIRECT); candidate = CourseConceptCandidate(candidate_id="candidate_1", canonical_name="Database normalization", description="Normalization reduces relational update anomalies.", concept_type=CourseConceptType.CORE, evidence=[ref], confidence=BlueprintConfidence.HIGH); merged = MergedCourseConcept(local_concept_key="concept_1", canonical_name=candidate.canonical_name, description=candidate.description, concept_type=CourseConceptType.CORE, evidence=[ref], confidence=BlueprintConfidence.HIGH, source_candidate_ids=[candidate.candidate_id]); outcome = BlueprintLearningOutcome(outcome_key="outcome_1", statement="Apply normalization to a relational schema.", level=LearningObjectiveLevel.APPLY, evidence=[ref], confidence=BlueprintConfidence.HIGH); module = CourseModuleDraft(module_key="module_1", title="Normalization", description="Learn and apply normalization.", order_index=0, importance=ModuleImportance.REQUIRED, concept_keys=[merged.local_concept_key], learning_outcome_keys=[outcome.outcome_key], evidence=[ref], confidence=BlueprintConfidence.HIGH, estimated_learning_hours=2.0); draft = CourseBlueprintDraft(schema_version=1, course_title="Database Systems", course_summary="A grounded database course.", concepts=[merged], learning_outcomes=[outcome], modules=[module], prerequisites=[], confidence=BlueprintConfidence.HIGH); return MockGenerationAI(analysis_output=CourseChunkAnalysis(chunk_id=chunk_id, summary="Normalization is covered.", concepts=[candidate], confidence=BlueprintConfidence.HIGH), merge_output=[merged], synthesis_output=draft, prerequisite_output=[], critique_output=BlueprintCritique(grounded=True, confidence=BlueprintConfidence.HIGH));
}

test "analysis planner enforces bounded count and token budgets" { chunks: list[CourseContentChunk] = []; for index in range(3) { chunks.append(CourseContentChunk(chunk_id="c" + str(index), document_id="d", extraction_id="e", track_id="t", track_version_id="v", chunking_strategy="s", order_index=index, content="x", character_count=1, word_count=1, estimated_token_count=7, source_block_ids_json="[]", content_hash="h" + str(index), created_at="now")); } config = default_blueprint_generation_config(); config.chunk_analysis_batch_size = 2; config.max_input_tokens_per_call = 10; units = plan_analysis_units(chunks, config); assert len(units) == 3 and units[0].total_estimated_tokens <= 10; }

test "blueprint generation requires active matching chunk set" { suffix = uuid4().hex; (track, document, chunk_set, _) = _fixture(suffix); document.is_active = False; service = CourseBlueprintGenerationService(ai=_mock("chk_" + suffix)); result = service.execute_generation(BlueprintGenerationContext(track_id=track.track_id, track_version_id=document.track_version_id, document_id=document.document_id, chunk_set_id=chunk_set.chunk_set_id, request_id="r", actor_id="u", config=default_blueprint_generation_config())); assert result.status == BlueprintGenerationStatus.FAILED and result.error_code == "BLUEPRINT_SOURCE_NOT_READY"; }

test "mock pipeline persists grounded draft and equivalent generation is idempotent" { suffix = uuid4().hex; (track, document, chunk_set, chunk) = _fixture(suffix); mock = _mock(chunk.chunk_id); service = CourseBlueprintGenerationService(ai=mock); context = BlueprintGenerationContext(track_id=track.track_id, track_version_id=document.track_version_id, document_id=document.document_id, chunk_set_id=chunk_set.chunk_set_id, request_id="r", actor_id="u", config=default_blueprint_generation_config()); first = service.execute_generation(context); second = service.execute_generation(context); version = repository_versions(track)[0]; blueprints = CourseBlueprintRepository().list_generations(version); assert first.status == BlueprintGenerationStatus.GENERATED and first.blueprint_id is not None and second.blueprint_id == first.blueprint_id; assert len(blueprints) == 1 and blueprints[0].is_active and first.concept_count == 1 and first.module_count == 1 and mock.analyze_calls == 1; }

test "successful chunk analyses are durable checkpoints" { suffix = uuid4().hex; (track, document, chunk_set, chunk) = _fixture(suffix); service = CourseBlueprintGenerationService(ai=_mock(chunk.chunk_id)); context = BlueprintGenerationContext(track_id=track.track_id, track_version_id=document.track_version_id, document_id=document.document_id, chunk_set_id=chunk_set.chunk_set_id, request_id="r", actor_id="u", config=default_blueprint_generation_config()); result = service.execute_generation(context); version = repository_versions(track)[0]; runs = BlueprintGenerationArtifactRepository().list_runs(version); assert result.status == BlueprintGenerationStatus.GENERATED and len(runs) == 1 and len(BlueprintGenerationArtifactRepository().list_chunk_analyses(runs[0])) == 1 and runs[0].current_step == "DRAFT_PERSISTED"; }

test "source replacement cannot activate obsolete generation" { suffix = uuid4().hex; (track, document, chunk_set, chunk) = _fixture(suffix); document.checksum = "changed-after-chunking"; result = CourseBlueprintGenerationService(ai=_mock(chunk.chunk_id)).execute_generation(BlueprintGenerationContext(track_id=track.track_id, track_version_id=document.track_version_id, document_id=document.document_id, chunk_set_id=chunk_set.chunk_set_id, request_id="r", actor_id="u", config=default_blueprint_generation_config())); assert result.status == BlueprintGenerationStatus.FAILED and len(CourseBlueprintRepository().list_generations(repository_versions(track)[0])) == 0; }

test "successful generation completes durable job and queues validation" { suffix = uuid4().hex; (track, document, chunk_set, chunk) = _fixture(suffix); service = CourseBlueprintGenerationService(ai=_mock(chunk.chunk_id)); context = BlueprintGenerationContext(track_id=track.track_id, track_version_id=document.track_version_id, document_id=document.document_id, chunk_set_id=chunk_set.chunk_set_id, request_id="r", actor_id="u", config=default_blueprint_generation_config()); queued = service.prepare_generation(context); generated = service.execute_generation(context); reconciled = DocumentProcessingOrchestrator().reconcile_completed_artifacts(document); jobs = DocumentProcessingJobRepository().list_jobs_for_document(document); generation_jobs = [item for item in jobs if item.stage == DocumentProcessingStage.BLUEPRINT_GENERATION]; validation_jobs = [item for item in jobs if item.stage == DocumentProcessingStage.BLUEPRINT_VALIDATION]; assert queued.status == BlueprintGenerationStatus.QUEUED and generated.status == BlueprintGenerationStatus.GENERATED and reconciled == 1; assert len(generation_jobs) == 1 and generation_jobs[0].status == ProcessingJobStatus.SUCCEEDED and len(validation_jobs) == 1 and validation_jobs[0].status == ProcessingJobStatus.QUEUED; }
