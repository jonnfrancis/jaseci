"""Safe validation telemetry without source or prompt content."""
import from lib.learning_track.application_services { service_now }
import from lib.observability.events { ObservabilityEvent }
import from lib.observability.logger { emit_event }

glob BLUEPRINT_VALIDATION_METRICS: dict[str, float] = {};
def record_blueprint_validation(status: str, duration_ms: int, source_ratio: float, concept_ratio: float, module_ratio: float, grounding_ratio: float, unsupported: int = 0, cycles: int = 0, dangling: int = 0) { BLUEPRINT_VALIDATION_METRICS["blueprint_validation_total"] = BLUEPRINT_VALIDATION_METRICS.get("blueprint_validation_total", 0.0) + 1.0; key = "blueprint_validation_" + ("warning" if status == "VALID_WITH_WARNINGS" else status.lower()) + "_total"; BLUEPRINT_VALIDATION_METRICS[key] = BLUEPRINT_VALIDATION_METRICS.get(key, 0.0) + 1.0; BLUEPRINT_VALIDATION_METRICS["blueprint_validation_duration_ms"] = BLUEPRINT_VALIDATION_METRICS.get("blueprint_validation_duration_ms", 0.0) + float(duration_ms); BLUEPRINT_VALIDATION_METRICS["blueprint_validation_source_coverage_ratio"] = source_ratio; BLUEPRINT_VALIDATION_METRICS["blueprint_validation_concept_coverage_ratio"] = concept_ratio; BLUEPRINT_VALIDATION_METRICS["blueprint_validation_module_coverage_ratio"] = module_ratio; BLUEPRINT_VALIDATION_METRICS["blueprint_validation_grounding_ratio"] = grounding_ratio; BLUEPRINT_VALIDATION_METRICS["blueprint_validation_unsupported_concepts_total"] = BLUEPRINT_VALIDATION_METRICS.get("blueprint_validation_unsupported_concepts_total", 0.0) + float(unsupported); BLUEPRINT_VALIDATION_METRICS["blueprint_validation_cycles_total"] = BLUEPRINT_VALIDATION_METRICS.get("blueprint_validation_cycles_total", 0.0) + float(cycles); BLUEPRINT_VALIDATION_METRICS["blueprint_validation_dangling_refs_total"] = BLUEPRINT_VALIDATION_METRICS.get("blueprint_validation_dangling_refs_total", 0.0) + float(dangling); }
def blueprint_validation_event(name: str, entity_ids: dict[str, object], attributes: dict[str, object], request_id: str, status: str = "completed", duration_ms: int = 0, error_code: str = "") { emit_event(ObservabilityEvent(timestamp=service_now(), level="error" if status in ["failed", "invalid"] else "info", event="blueprint_validation." + name, status=status, message="Blueprint validation state changed.", request_id=request_id, correlation_id=request_id, duration_ms=duration_ms, error_code=error_code, entity_ids=entity_ids, attributes=attributes)); }
