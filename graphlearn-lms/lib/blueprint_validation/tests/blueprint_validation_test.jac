"""Feature 48 grounding, coverage, graph-consistency, cycle, and history tests."""
import from uuid { uuid4 }
import from edges.domain_edges { HAS_BLUEPRINT_CONCEPT, HAS_BLUEPRINT_MODULE, HAS_BLUEPRINT_OUTCOME, HAS_BLUEPRINT_PREREQUISITE, HAS_CHUNK_SET, HAS_CONTENT_CHUNK, HAS_EXTRACTION, HAS_SOURCE_DOCUMENT }
import from lib.blueprint_validation.repositories { BlueprintValidationRepository }
import from lib.blueprint_validation.service { BlueprintValidationService }
import from lib.course_blueprint.repositories { CourseBlueprintRepository }
import from lib.curriculum_graph.service { TopicSkillGraphGenerationService }
import from lib.learning_track.course_management { create_course_service }
import from lib.learning_track.repositories { repository_find_track, repository_versions }
import from lib.learning_track.repository_types { ActorContext }
import from nodes.curriculum { BlueprintConcept, BlueprintGenerationStatus, BlueprintLearningOutcomeNode, BlueprintModule, BlueprintPrerequisite, BlueprintValidationContext, BlueprintValidationReport, BlueprintValidationStatus, CourseBlueprint, CourseContentChunk, CourseDocument, CourseDocumentProcessingStatus, CourseDocumentUploadStatus, DocumentChunkSet, DocumentChunkingStatus, DocumentExtraction, DocumentExtractionStatus, DocumentValidationStatus, GraphGenerationContext }
import from nodes.learning_track { CreateCourseTrackInput, LearningTrack, LecturerCourseDetail, TrackVersion, TrackVersionStatus }

def _fixture(suffix: str) -> tuple[LearningTrack, TrackVersion, CourseBlueprint, BlueprintConcept, str] {
    actor = ActorContext(user_id="user_" + suffix, lecturer_id="lecturer_" + suffix, request_id="request_" + suffix, roles=["LECTURER"]); created = create_course_service(actor, CreateCourseTrackInput(title="Validated Databases " + suffix[:5], client_request_id="validation_" + suffix)); detail = created.value as LecturerCourseDetail; track = repository_find_track(detail.track.track_id) as LearningTrack; version = repository_versions(track)[0];
    document = CourseDocument(document_id="doc_" + suffix, track_id=track.track_id, track_version_id=version.track_version_id, original_filename="notes.pdf", normalized_filename="notes.pdf", mime_type="application/pdf", file_extension="pdf", file_size_bytes=1000, storage_provider="test", storage_key="test/notes.pdf", checksum_algorithm="sha256", checksum="checksum_" + suffix, upload_status=CourseDocumentUploadStatus.STORED, processing_status=CourseDocumentProcessingStatus.ANALYZING, uploaded_by=actor.user_id, uploaded_at="now", updated_at="now", idempotency_scope="scope_" + suffix, validation_status=DocumentValidationStatus.VALIDATED, extraction_status=DocumentExtractionStatus.EXTRACTED, chunking_status=DocumentChunkingStatus.CHUNKED); version +>:HAS_SOURCE_DOCUMENT(attached_at="now", attached_by=actor.user_id):+> document;
    extraction = DocumentExtraction(extraction_id="ext_" + suffix, document_id=document.document_id, track_id=track.track_id, track_version_id=version.track_version_id, status=DocumentExtractionStatus.EXTRACTED, extractor_name="test", extractor_version="1", source_checksum_sha256=document.checksum, is_active=True); document +>:HAS_EXTRACTION(created_at="now"):+> extraction;
    chunk_set = DocumentChunkSet(chunk_set_id="chs_" + suffix, document_id=document.document_id, extraction_id=extraction.extraction_id, track_id=track.track_id, track_version_id=version.track_version_id, source_checksum_sha256=document.checksum, schema_version=1, strategy_name="test", config_hash="cfg", status=DocumentChunkingStatus.CHUNKED, created_at="now", chunk_count=1, source_coverage_ratio=1.0, is_active=True); extraction +>:HAS_CHUNK_SET(created_at="now"):+> chunk_set;
    chunk = CourseContentChunk(chunk_id="chk_" + suffix, document_id=document.document_id, extraction_id=extraction.extraction_id, track_id=track.track_id, track_version_id=version.track_version_id, chunking_strategy="test", order_index=0, content="Database foundations explain relational keys. Apply database foundations to practical applications.", character_count=92, word_count=10, estimated_token_count=20, source_block_ids_json="[]", content_hash="hash", created_at="now", page_start=1, page_end=1); chunk_set +>:HAS_CONTENT_CHUNK(order_index=0):+> chunk;
    evidence = "[{\"chunk_id\":\"" + chunk.chunk_id + "\",\"quote_hint\":\"database foundations\",\"page_start\":1,\"page_end\":1,\"strength\":\"DIRECT\"}]";
    blueprint = CourseBlueprint(blueprint_id="bp_" + suffix, track_id=track.track_id, track_version_id=version.track_version_id, document_id=document.document_id, extraction_id=extraction.extraction_id, chunk_set_id=chunk_set.chunk_set_id, schema_version=1, generation_status=BlueprintGenerationStatus.GENERATED, source_checksum_sha256=document.checksum, course_title="Databases", course_summary="Grounded database foundations.", confidence="HIGH", created_at="now", updated_at="now", generation_identity="identity_" + suffix, is_active=True, source_coverage_ratio=1.0, concept_coverage_ratio=1.0, module_coverage_ratio=1.0); CourseBlueprintRepository().save_blueprint_shell(version, blueprint);
    concept = BlueprintConcept(blueprint_concept_id="bpc_" + suffix, blueprint_id=blueprint.blueprint_id, local_concept_key="concept_a", canonical_name="Database foundations", description="Relational database keys and foundations.", concept_type="CORE", aliases_json="[]", learning_objectives_json="[]", key_terms_json="[\"relational\",\"keys\"]", confidence="HIGH", should_be_taught_explicitly=True, evidence_json=evidence); module = BlueprintModule(blueprint_module_id="bpm_" + suffix, blueprint_id=blueprint.blueprint_id, local_module_key="module_a", title="Database foundations", description="Grounded database foundations.", order_index=0, importance="REQUIRED", concept_keys_json="[\"concept_a\"]", learning_outcome_keys_json="[\"outcome_a\"]", confidence="HIGH", evidence_json=evidence, warnings_json="[]", estimated_learning_hours=2.0); outcome = BlueprintLearningOutcomeNode(blueprint_outcome_id="bpo_" + suffix, blueprint_id=blueprint.blueprint_id, local_outcome_key="outcome_a", statement="Apply database foundations to relational keys.", level="APPLY", confidence="HIGH", evidence_json=evidence); blueprint +>:HAS_BLUEPRINT_CONCEPT:+> concept; blueprint +>:HAS_BLUEPRINT_MODULE(order_index=0):+> module; blueprint +>:HAS_BLUEPRINT_OUTCOME:+> outcome; return (track, version, blueprint, concept, evidence);
}

def _generate(track: LearningTrack, version: TrackVersion, blueprint: CourseBlueprint) -> str { result = TopicSkillGraphGenerationService().generate_graph(blueprint.blueprint_id, GraphGenerationContext(track_id=track.track_id, track_version_id=version.track_version_id, blueprint_id=blueprint.blueprint_id, request_id="graph")); return result.graph_generation_id as str; }
def _context(track: LearningTrack, version: TrackVersion, blueprint: CourseBlueprint, graph_id: str, force: bool = False) -> BlueprintValidationContext { return BlueprintValidationContext(track_id=track.track_id, track_version_id=version.track_version_id, blueprint_id=blueprint.blueprint_id, graph_generation_id=graph_id, request_id="validation", force_revalidate=force); }

test "complete grounded blueprint becomes review ready and reuses report" { suffix = uuid4().hex; (track, version, blueprint, _, _) = _fixture(suffix); graph_id = _generate(track, version, blueprint); service = BlueprintValidationService(); first = service.validate_blueprint(blueprint.blueprint_id, _context(track, version, blueprint, graph_id)); second = service.validate_blueprint(blueprint.blueprint_id, _context(track, version, blueprint, graph_id)); assert first.status == BlueprintValidationStatus.VALID and first.eligible_for_review and first.grounding_ratio == 1.0 and version.status == TrackVersionStatus.REVIEW_REQUIRED; assert second.reused and second.validation_report_id == first.validation_report_id and len(BlueprintValidationRepository().list_reports(blueprint)) == 1; }

test "unsupported required concept blocks lecturer review" { suffix = uuid4().hex; (track, version, blueprint, concept, _) = _fixture(suffix); graph_id = _generate(track, version, blueprint); concept.canonical_name = "Raft consensus"; concept.description = "Distributed consensus elections and replicated logs."; blueprint.updated_at = "changed"; result = BlueprintValidationService().validate_blueprint(blueprint.blueprint_id, _context(track, version, blueprint, graph_id, True)); latest = BlueprintValidationRepository().find_latest_report(blueprint); codes = [item.code for item in BlueprintValidationRepository().list_issues(latest as BlueprintValidationReport)]; assert result.status == BlueprintValidationStatus.INVALID and not result.eligible_for_review and "BLUEPRINT_UNSUPPORTED_CONCEPT" in codes; }

test "unknown evidence reference invalidates blueprint" { suffix = uuid4().hex; (track, version, blueprint, concept, _) = _fixture(suffix); graph_id = _generate(track, version, blueprint); concept.evidence_json = "[{\"chunk_id\":\"missing\",\"strength\":\"DIRECT\"}]"; blueprint.updated_at = "changed"; result = BlueprintValidationService().validate_blueprint(blueprint.blueprint_id, _context(track, version, blueprint, graph_id, True)); latest = BlueprintValidationRepository().find_latest_report(blueprint); codes = [item.code for item in BlueprintValidationRepository().list_issues(latest as BlueprintValidationReport)]; assert result.status == BlueprintValidationStatus.INVALID and "BLUEPRINT_INVALID_EVIDENCE_REFERENCE" in codes; }

test "required prerequisite cycle is critical and history is preserved" { suffix = uuid4().hex; (track, version, blueprint, _, evidence) = _fixture(suffix); second = BlueprintConcept(blueprint_concept_id="second_" + suffix, blueprint_id=blueprint.blueprint_id, local_concept_key="concept_b", canonical_name="Practical applications", description="Apply database foundations.", concept_type="APPLIED", aliases_json="[]", learning_objectives_json="[]", key_terms_json="[\"applications\"]", confidence="HIGH", should_be_taught_explicitly=True, evidence_json=evidence); blueprint +>:HAS_BLUEPRINT_CONCEPT:+> second; modules = CourseBlueprintRepository().list_modules(blueprint); modules[0].concept_keys_json = "[\"concept_a\",\"concept_b\"]"; first_edge = BlueprintPrerequisite(blueprint_prerequisite_id="p1_" + suffix, blueprint_id=blueprint.blueprint_id, prerequisite_concept_key="concept_a", dependent_concept_key="concept_b", strength="REQUIRED", rationale="First.", confidence="HIGH", evidence_json=evidence); blueprint +>:HAS_BLUEPRINT_PREREQUISITE:+> first_edge; graph_id = _generate(track, version, blueprint); service = BlueprintValidationService(); valid = service.validate_blueprint(blueprint.blueprint_id, _context(track, version, blueprint, graph_id)); version.status = TrackVersionStatus.DRAFT; blueprint.generation_status = BlueprintGenerationStatus.GENERATED; blueprint +>:HAS_BLUEPRINT_PREREQUISITE:+> BlueprintPrerequisite(blueprint_prerequisite_id="p2_" + suffix, blueprint_id=blueprint.blueprint_id, prerequisite_concept_key="concept_b", dependent_concept_key="concept_a", strength="REQUIRED", rationale="Cycle.", confidence="HIGH", evidence_json=evidence); blueprint.updated_at = "changed"; invalid = service.revalidate_blueprint(blueprint.blueprint_id, _context(track, version, blueprint, graph_id)); latest = BlueprintValidationRepository().find_latest_report(blueprint); issues = BlueprintValidationRepository().list_issues(latest as BlueprintValidationReport); assert valid.eligible_for_review and invalid.status == BlueprintValidationStatus.INVALID and len([item for item in issues if item.code == "BLUEPRINT_PREREQUISITE_CYCLE" and str(item.severity) == "CRITICAL"]) == 1; assert len(BlueprintValidationRepository().list_reports(blueprint)) == 2; }
