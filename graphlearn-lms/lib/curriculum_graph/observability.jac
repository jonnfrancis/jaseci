"""Safe low-cardinality curriculum graph generation telemetry."""
import from lib.learning_track.application_services { service_now }
import from lib.observability.events { ObservabilityEvent }
import from lib.observability.logger { emit_event }

glob CURRICULUM_GRAPH_METRICS: dict[str, int] = {};
def record_curriculum_graph_generation(result: str, duration_ms: int = 0, modules: int = 0, skills: int = 0, prerequisites: int = 0, cycles: int = 0, orphans: int = 0) { CURRICULUM_GRAPH_METRICS["curriculum_graph_generation_total"] = CURRICULUM_GRAPH_METRICS.get("curriculum_graph_generation_total", 0) + 1; if result == "failed" { CURRICULUM_GRAPH_METRICS["curriculum_graph_generation_failed_total"] = CURRICULUM_GRAPH_METRICS.get("curriculum_graph_generation_failed_total", 0) + 1; } CURRICULUM_GRAPH_METRICS["curriculum_graph_modules_total"] = CURRICULUM_GRAPH_METRICS.get("curriculum_graph_modules_total", 0) + modules; CURRICULUM_GRAPH_METRICS["curriculum_graph_skills_total"] = CURRICULUM_GRAPH_METRICS.get("curriculum_graph_skills_total", 0) + skills; CURRICULUM_GRAPH_METRICS["curriculum_graph_prerequisites_total"] = CURRICULUM_GRAPH_METRICS.get("curriculum_graph_prerequisites_total", 0) + prerequisites; CURRICULUM_GRAPH_METRICS["curriculum_graph_cycles_detected_total"] = CURRICULUM_GRAPH_METRICS.get("curriculum_graph_cycles_detected_total", 0) + cycles; CURRICULUM_GRAPH_METRICS["curriculum_graph_orphans_detected_total"] = CURRICULUM_GRAPH_METRICS.get("curriculum_graph_orphans_detected_total", 0) + orphans; CURRICULUM_GRAPH_METRICS["curriculum_graph_generation_duration_ms"] = CURRICULUM_GRAPH_METRICS.get("curriculum_graph_generation_duration_ms", 0) + duration_ms; }
def curriculum_graph_event(name: str, entity_ids: dict[str, object], counts: dict[str, object], request_id: str, status: str = "completed", duration_ms: int = 0, error_code: str = "") { emit_event(ObservabilityEvent(timestamp=service_now(), level="error" if status == "failed" else "info", event="curriculum_graph." + name, status=status, message="Curriculum graph generation state changed.", request_id=request_id, correlation_id=request_id, duration_ms=duration_ms, error_code=error_code, entity_ids=entity_ids, attributes=counts)); }
